# LeadForge frontend environment variables.
#
# Copy this file to `.env.local` (gitignored) and adjust as needed.
# The dashboard reads these via Next.js's NEXT_PUBLIC_* convention.

# Base URL of the LeadForge FastAPI backend.
# Used by Add Leads preview/process and by API-backed dashboard mode.
# In Vercel, set this to the deployed backend base URL, for example:
# NEXT_PUBLIC_API_URL=https://your-render-service.onrender.com
# Do not put secrets in NEXT_PUBLIC_* variables; they are browser-visible.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Data source for the demo dashboard (default: mock).
#   - "mock" -> bundled mock data in lib/mock-data.ts
#   - "api"  -> FastAPI backend at NEXT_PUBLIC_API_URL
NEXT_PUBLIC_DATA_SOURCE=mock

# Do not add NEXT_PUBLIC_DEMO_ACCESS_CODE. If the backend sets
# DEMO_ACCESS_CODE, the demo page prompts for it at runtime and stores it only
# in sessionStorage for the current browser tab.
