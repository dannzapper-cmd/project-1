# LeadForge frontend environment variables.
#
# Copy this file to `.env.local` (gitignored) and adjust as needed.
# The dashboard reads these via Next.js's NEXT_PUBLIC_* convention.

# Base URL of the LeadForge FastAPI backend.
# Used by `lib/api/client.ts` when DATA_SOURCE=api.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Data source for the demo dashboard. Phase 7.0 default is "mock";
# Phase 7.1 will switch this to "api" once the dashboard components
# consume the API client.
#   - "mock" -> reads lib/mock-data.ts (current behaviour)
#   - "api"  -> reads from NEXT_PUBLIC_API_URL via lib/api/client.ts
NEXT_PUBLIC_DATA_SOURCE=mock
