# =============================================================================
# LeadForge Backend — Environment Variables
# Copy this file to `.env` and adjust as needed:
#   cp .env.example .env
# =============================================================================

# -- Application -------------------------------------------------------------
APP_NAME=leadforge-backend
APP_ENV=development
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# Optional deployment traceability value set by Render/Vercel CI.
BUILD_SHA=

# -- Database ----------------------------------------------------------------
# SQLite local file. Path is relative to the backend/ working directory.
DATABASE_URL=sqlite:///./leadforge.db

# -- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for the Next.js frontend.
# Production must use explicit origins; wildcard "*" is rejected when
# APP_ENV=production. Add your Vercel domain without a trailing slash.
# Example:
# CORS_ORIGINS=https://your-project.vercel.app,http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# Optional and future-facing variables
# Groq and ENABLE_LIVE_MODEL_PIPELINE are read by the app when configured.
# Keep real secrets out of this template.
# =============================================================================

# -- Model providers (future) -------------------------------------------------
# MODEL_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# -- Groq provider (optional) ------------------------------------------------
# Optional. Required only for opt-in Groq smoke/live tests and groq-check.
# The app starts normally without a key; groq-check returns HTTP 503 when unset.
# Never commit a real key.
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=30

# -- Block 8.3: live Groq single-lead pipeline (opt-in) ----------------------
# OFF by default. When set to "true" AND GROQ_API_KEY is also set, the
# POST /api/demo/pipeline/live-groq/{lead_id} endpoint may incur real Groq
# API cost. The deterministic pipeline at GET /api/demo/pipeline/{lead_id}
# is unaffected and remains the safe baseline. The live pipeline enforces a
# hard total-token budget per request (MAX_LIVE_TOKENS_PER_RUN = 8000
# tokens, defined in app/services/live_pipeline_service.py) and never
# retries on rate limits or provider errors. The Groq model is resolved
# from GROQ_DEFAULT_MODEL above, so changing models is a one-line env-var
# change and does not require touching the live pipeline code.
ENABLE_LIVE_MODEL_PIPELINE=false

# -- Block 11B: public demo safety controls ----------------------------------
# In-memory only. Counters reset when Render Free spins down/restarts.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_LIVE_REQUESTS_PER_MINUTE=5

# Optional abuse-deterrence gate for expensive/state-changing demo actions.
# Do not place this value in any NEXT_PUBLIC_* frontend env var.
DEMO_ACCESS_CODE=

# Intake and batch controls for the public demo.
MAX_LEADS_PER_RUN=10
INTAKE_MAX_UPLOAD_MB=5
# MAX_UPLOAD_SIZE_MB=5

# -- Cost / run limits (future) ----------------------------------------------
# MAX_AGENT_STEPS=6
# MAX_TOKENS_PER_LEAD=8000
# DAILY_DEMO_BUDGET_USD=1

# -- Block 10E: live web research (Exa) --------------------------------------
# OFF by default. Manual, single-lead trigger surfaced in the UI as
# "Run live research". The Exa API key is read backend-side only; do
# NOT mirror it into any NEXT_PUBLIC_* variable. The endpoint at
# POST /api/research/live-company always returns HTTP 200 with a
# structured body; disabled / unavailable / rate-limited / timeout
# / no-evidence states are encoded in `status` (not in HTTP codes).
#
# Daily limit is enforced by an in-process counter that resets on
# backend restart — do not raise it past a low value for the public demo.
ENABLE_LIVE_RESEARCH=false
EXA_API_KEY=
LIVE_RESEARCH_MAX_RESULTS=3
LIVE_RESEARCH_TIMEOUT_SECONDS=8
LIVE_RESEARCH_DAILY_LIMIT=20

# -- Block 10G: contextual LLM lead assistant (opt-in) -----------------------
# OFF by default. When ENABLE_LLM_ASSISTANT=true AND GROQ_API_KEY is set, the
# POST /api/assistant/lead-question endpoint forwards a small structured
# lead-context payload to the existing Groq provider for a grounded answer.
# Manual trigger only — no model calls are made on page load or while typing.
# The assistant has no tools: no web browsing, no email sending, no CRM
# writes, no live research, no batch over all leads.
#
# The Groq API key, default model, and timeout are reused from the GROQ_*
# variables above — there is intentionally no parallel API key for the
# assistant. LLM_ASSISTANT_MODEL is the pinned Groq model name; do NOT use
# "latest" or any auto-resolving alias. Leave it equal to GROQ_DEFAULT_MODEL
# so the live pipeline and the assistant stay in sync.
#
# All rate limits use in-process counters that reset on backend restart —
# no Redis, no DB, no persistence.
ENABLE_LLM_ASSISTANT=false
LLM_ASSISTANT_PROVIDER=groq
LLM_ASSISTANT_MODEL=llama-3.1-8b-instant
LLM_ASSISTANT_MAX_QUESTION_CHARS=300
LLM_ASSISTANT_TIMEOUT_SECONDS=12
LLM_ASSISTANT_DAILY_LIMIT=30
LLM_ASSISTANT_PER_IP_LIMIT=5
LLM_ASSISTANT_PER_IP_WINDOW_SECONDS=600

# -- Feature flags (future) --------------------------------------------------
# ENABLE_EMAIL_SENDING=false

# -- Vector DB / RAG (future) ------------------------------------------------
# CHROMA_PERSIST_DIR=./.chroma
